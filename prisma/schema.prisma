generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContactStatus {
  ACTUAL
  FUTURO
  HISTORICO
}

enum Language {
  ES
  EN
  DE
  FR
  IT
  PT
}

model Contact {
  id         String        @id @default(uuid())
  name       String
  roomNumber String?
  phone      String
  language   Language
  checkinUrl String?
  status     ContactStatus
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  taxiRequests TaxiRequest[]
}

model MessageCategory {
  id       String    @id @default(uuid())
  name     String
  messages Message[]
}

model Message {
  id         String          @id @default(uuid())
  baseKey    String
  categoryId String
  category   MessageCategory @relation(fields: [categoryId], references: [id])
  language   Language
  content    String
  order      Int             @default(0)
  createdAt  DateTime        @default(now())

  @@index([baseKey])
  @@index([categoryId, order])
}

// =======================
// FIRMA GLOBAL
// =======================
model Signature {
  id        String   @id @default(uuid())
  content   String
  updatedAt DateTime @updatedAt
}

model TaxiCompany {
  id        String   @id @default(uuid())
  name      String
  phone     String

  createdAt DateTime @default(now())

  taxiRequests TaxiRequest[]
}

model TaxiRequest {
  id            String   @id @default(uuid())

  taxiCompanyId String
  contactId     String

  date          DateTime
  origin        String
  destination   String
  passengers    Int

  message       String

  createdAt     DateTime @default(now())

  taxiCompany TaxiCompany @relation(fields: [taxiCompanyId], references: [id])
  contact     Contact     @relation(fields: [contactId], references: [id])
}

// =======================
// ROOM TYPES
// =======================
model RoomType {
  id          String   @id @default(uuid())
  name        String
  description String?
  icon        String?
  createdAt   DateTime @default(now())
}